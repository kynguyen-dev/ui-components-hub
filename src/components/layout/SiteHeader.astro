---
import { Menu, Github, Sparkles } from 'lucide-react';
import { ThemeToggle } from '@/components/ThemeToggle';
import { CommandMenu, SearchTrigger } from '@/components/CommandMenu';

const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Home', active: currentPath === '/' },
  { href: '/components', label: 'Components', active: currentPath.startsWith('/components') },
  { href: '/docs', label: 'Docs', active: currentPath.startsWith('/docs') },
];
---

<header class="sticky top-0 z-50 border-b border-border/70 bg-background/90 backdrop-blur supports-[backdrop-filter]:bg-background/70">
  <div class="site-shell relative grid h-16 grid-cols-[auto_1fr_auto] items-center gap-4 xl:grid-cols-[auto_1fr_auto]">
    <a href="/" class="flex min-w-0 items-center gap-3 text-foreground">
      <span class="flex min-w-0 flex-col leading-none">
        <span class="text-[0.72rem] font-semibold tracking-[0.24em] text-muted-foreground uppercase">UI Hub</span>
        <span class="mt-1 text-base font-semibold">Astro Docs Platform</span>
      </span>
    </a>

    <nav class="absolute left-1/2 hidden -translate-x-1/2 items-center justify-center gap-1 lg:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'rounded-full px-4 py-2 text-sm font-medium transition-colors',
            item.active
              ? 'bg-muted text-foreground'
              : 'text-muted-foreground hover:bg-muted hover:text-foreground',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center justify-end gap-2">
      <SearchTrigger client:load />
      <a
        href="https://github.com/kynguyen-dev/ui-components-hub"
        target="_blank"
        rel="noreferrer"
        class="hidden rounded-full border border-border px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground md:inline-flex md:items-center md:gap-2"
      >
        <Github className="h-4 w-4" />
        GitHub
      </a>
      <ThemeToggle client:load />
      <details class="relative lg:hidden">
        <summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-full border border-border bg-background text-foreground marker:hidden">
          <Menu className="h-5 w-5" />
        </summary>
        <div class="absolute right-0 mt-3 w-64 rounded-2xl border border-border bg-background p-3 shadow-xl">
          <div class="mb-2 flex items-center gap-2 rounded-xl bg-muted/60 px-3 py-2 text-sm font-medium">
            <Sparkles className="h-4 w-4 text-primary" />
            Hybrid Astro Docs
          </div>
          <div class="grid gap-1">
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  'rounded-xl px-3 py-2 text-sm transition-colors',
                  item.active
                    ? 'bg-muted text-foreground'
                    : 'text-muted-foreground hover:bg-muted hover:text-foreground',
                ]}
              >
                {item.label}
              </a>
            ))}
            <a
              href="https://github.com/kynguyen-dev/ui-components-hub"
              target="_blank"
              rel="noreferrer"
              class="rounded-xl px-3 py-2 text-sm text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
            >
              GitHub
            </a>
          </div>
        </div>
      </details>
    </div>
  </div>
</header>

<!-- Global command menu rendered once, triggered by keyboard shortcut or SearchTrigger click -->
<CommandMenu client:load />
