---
import MainLayout from '@/layouts/MainLayout.astro';
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { ArrowRight, Box, CreditCard, Layers, Layout, MousePointer2, Type } from 'lucide-react';
import {
  getCategorySummaries,
  getComponentEntries,
  getFeaturedComponentEntries,
  getLibrarySummaries,
} from '@/lib/docs';

const [categories, featuredComponents, components, librarySummaries] = await Promise.all([
  getCategorySummaries(),
  getFeaturedComponentEntries(6),
  getComponentEntries(),
  getLibrarySummaries(),
]);

const iconMap = {
  Buttons: MousePointer2,
  Cards: CreditCard,
  'Hero Sections': Layout,
  Backgrounds: Box,
  Typography: Type,
  Layouts: Layers,
} as const;
---

<MainLayout
  title="Browse Components | UI Components Hub"
  description="Browse typed component documentation sourced from Astro content collections."
>
  <section class="site-shell py-12">
    <div class="space-y-3">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-primary">Component Catalog</p>
      <h1 class="text-4xl font-semibold tracking-tight">Explore the content-driven component registry</h1>
      <p class="max-w-2xl text-muted-foreground">
        Every card here is generated from shared component metadata so categories, libraries, and featured components stay in sync across the catalog.
      </p>
    </div>

    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((category) => (
        <div class="group">
          <Card className="h-full transition-all group-hover:border-primary group-hover:shadow-md">
            <CardHeader>
              <div class="mb-2 w-fit rounded-lg bg-primary/10 p-2 text-primary group-hover:bg-primary group-hover:text-primary-foreground transition-colors">
                {(() => {
                  const Icon = iconMap[category.title as keyof typeof iconMap] ?? Layers;
                  return <Icon className="h-6 w-6" />;
                })()}
              </div>
              <CardTitle>{category.title}</CardTitle>
              <CardDescription>{category.description}</CardDescription>
            </CardHeader>
            <CardContent>
              <div class="flex items-center text-sm text-muted-foreground">
                <span class="font-medium">{category.count} components</span>
              </div>
            </CardContent>
          </Card>
        </div>
      ))}
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
      <div class="rounded-[2rem] border border-border bg-card p-8">
        <div class="flex items-center justify-between gap-4">
          <div>
            <h2 class="text-2xl font-semibold">Featured components</h2>
            <p class="mt-2 text-sm text-muted-foreground">High-signal component entries with previews, source references, and typed metadata.</p>
          </div>
          <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
            {components.length} total entries
          </span>
        </div>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {featuredComponents.map((entry) => (
            <div class="rounded-2xl border border-border bg-background p-5 transition-colors hover:border-primary/60">
              <div class="flex items-center justify-between gap-3">
                <h3 class="font-semibold">{entry.title}</h3>
                <ArrowRight className="h-4 w-4 text-muted-foreground" />
              </div>
              <p class="mt-2 text-sm text-muted-foreground">{entry.description}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                <span class="rounded-full bg-muted px-3 py-1 text-xs font-medium">{entry.library}</span>
                <span class="rounded-full bg-muted px-3 py-1 text-xs font-medium">{entry.status}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="rounded-[2rem] border border-border bg-muted/40 p-8">
        <h2 class="text-2xl font-semibold">Library coverage</h2>
        <div class="mt-6 space-y-3">
          {librarySummaries.map((library) => (
            <div class="flex items-center justify-between rounded-2xl border border-border bg-background px-4 py-4 transition-colors hover:border-primary/60">
              <span class="font-medium">{library.title}</span>
              <span class="text-sm text-muted-foreground">{library.count} component group{library.count > 1 ? 's' : ''}</span>
            </div>
          ))}
        </div>
        <div class="mt-8 rounded-2xl border border-dashed border-border bg-background px-4 py-5">
          <h3 class="font-medium">Missing something?</h3>
          <p class="mt-2 text-sm text-muted-foreground">
            New categories should start in the shared component metadata source so discovery and featured sections update automatically.
          </p>
          <Button variant="outline" className="mt-4" asChild>
            <a href="https://github.com/kynguyen-dev/ui-components-hub/issues" target="_blank">
              Request Component
            </a>
          </Button>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
