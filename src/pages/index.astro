---
import MainLayout from '@/layouts/MainLayout.astro';
import { Button } from '@/components/ui/button';
import { ArrowRight, Layers3, Sparkles } from 'lucide-react';
import {
  getCategorySummaries,
  getFeaturedComponentEntries,
  getLibrarySummaries,
} from '@/lib/docs';

const [featuredComponents, categorySummaries, librarySummaries] = await Promise.all([
  getFeaturedComponentEntries(3),
  getCategorySummaries(),
  getLibrarySummaries(),
]);
---

<MainLayout
  title="UI Components Hub | Home"
  description="A curated Astro and React component hub for browsing polished UI patterns."
>
  <section class="site-shell py-14 md:py-20">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
      <div class="space-y-6">
        <div class="inline-flex items-center gap-2 rounded-full border border-border bg-muted/60 px-4 py-2 text-sm text-muted-foreground">
          <Sparkles className="h-4 w-4 text-primary" />
          Astro + React + Tailwind
        </div>
        <div class="space-y-4">
          <h1 class="max-w-4xl text-4xl font-semibold tracking-tight sm:text-5xl md:text-6xl">
            Explore a component hub built for speed, clarity, and polished UI discovery.
          </h1>
          <p class="max-w-2xl text-lg text-muted-foreground">
            UI Components Hub curates reusable interface patterns across Astro and React workflows, with a fast catalog experience and focused interactive previews where they matter.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <Button size="lg" className="gap-2" asChild>
            <a href="/components">
              Browse Components <ArrowRight className="h-4 w-4" />
            </a>
          </Button>
        </div>
      </div>

      <div class="grid gap-4">
        <div class="rounded-3xl border border-border bg-card p-6 shadow-sm">
          <div class="mb-4 flex items-center gap-2 text-sm font-medium text-muted-foreground">
            <Layers3 className="h-4 w-4 text-primary" />
            Platform summary
          </div>
          <div class="grid gap-4 sm:grid-cols-3">
            <div>
              <p class="text-3xl font-semibold">{categorySummaries.length}</p>
              <p class="text-sm text-muted-foreground">component categories</p>
            </div>
            <div>
              <p class="text-3xl font-semibold">{librarySummaries.length}</p>
              <p class="text-sm text-muted-foreground">library references</p>
            </div>
          </div>
        </div>
        <div class="rounded-3xl border border-border bg-muted/40 p-6">
          <p class="text-sm font-medium text-foreground">Featured components</p>
          <div class="mt-4 space-y-3">
            {featuredComponents.map((entry) => (
              <div class="block rounded-2xl border border-border bg-background px-4 py-4">
                <div class="flex items-center justify-between gap-4">
                  <div>
                    <p class="font-medium">{entry.title}</p>
                    <p class="mt-1 text-sm text-muted-foreground">{entry.description}</p>
                  </div>
                  <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
                    {entry.category}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="site-shell grid gap-6 py-6 md:grid-cols-3">
      {categorySummaries.map((category) => (
      <div class="rounded-3xl border border-border bg-card p-6 transition-transform hover:-translate-y-1">
        <p class="text-sm font-medium text-primary">{category.count} entries</p>
        <h2 class="mt-3 text-2xl font-semibold">{category.title}</h2>
        <p class="mt-2 text-sm text-muted-foreground">{category.description}</p>
      </div>
    ))}
  </section>
</MainLayout>
